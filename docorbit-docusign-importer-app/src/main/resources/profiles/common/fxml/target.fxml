<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<TabPane prefHeight="550.0" prefWidth="850.0"
	tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/8.0.171"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.techtiera.docorbit.controller.TargetController">
	<tabs>
		<Tab text="Set up">
			<content>
				<AnchorPane style="-fx-background-color: #f6f6f8;">
					<children>
						<AnchorPane layoutX="21.0" layoutY="34.0"
							prefHeight="430.0" prefWidth="320.0"
							style="-fx-background-color: #ffffff; -fx-background-radius: 10;"
							AnchorPane.bottomAnchor="54.0" AnchorPane.leftAnchor="21.0"
							AnchorPane.topAnchor="34.0">
							<children>
								<SplitPane fx:id="targetSplitPane" layoutX="10.0"
									layoutY="10.0" prefHeight="510.0" prefWidth="300.0"
									style="-fx-background-color: #f6f6f8; -fx-background-radius: 10;"
									AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0"
									AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0" />
							</children>
							<effect>
								<InnerShadow height="10.0" radius="4.5" width="10.0" />
							</effect>
						</AnchorPane>
						<AnchorPane layoutX="377.0" layoutY="35.0"
							style="-fx-background-color: #ffffff; -fx-background-radius: 10;"
							AnchorPane.bottomAnchor="56.0" AnchorPane.leftAnchor="377.0"
							AnchorPane.rightAnchor="23.0" AnchorPane.topAnchor="35.0">
							<children>
								<Label fx:id="targetPathLabel" layoutX="30.0"
									layoutY="115.0" prefHeight="200.0" prefWidth="390.0"
									style="-fx-background-color: #f6f6f8; -fx-background-radius: 10;"
									text="Target Path : " textFill="#0d3073"
									AnchorPane.bottomAnchor="115.0" AnchorPane.leftAnchor="30.0"
									AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="115.0">
									<font>
										<Font name="Poppins Bold" size="12.0" />
									</font>
									<padding>
										<Insets left="10.0" right="10.0" />
									</padding>
									<effect>
										<InnerShadow height="10.0" radius="4.5"
											width="10.0" />
									</effect>
								</Label>
							</children>
							<effect>
								<InnerShadow height="10.0" radius="4.5" width="10.0" />
							</effect>
						</AnchorPane>
					</children>
				</AnchorPane>
			</content>
		</Tab>
	</tabs>
</TabPane>
