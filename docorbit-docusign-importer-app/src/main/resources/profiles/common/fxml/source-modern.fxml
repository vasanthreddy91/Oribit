							<Label style="-fx-font-size: 22px; -fx-text-fill: #4695c4; -fx-background-color: #EEF2FF; -fx-background-radius: 10; -fx-padding: 6 10 6 10;" text="👥" />
							<VBox spacing="2.0">
								<Label id="titleLabel" text="Users Import Configuration" />
								<Label id="subtitleLabel" text="Import user data from XML files" />
							</VBox>
						</HBox>

						<!-- Divider -->
						<Region maxHeight="1.0" minHeight="1.0" prefHeight="1.0" style="-fx-background-color: #E5E7EB;" />

						<!-- Body -->
						<VBox spacing="16.0" style="-fx-padding: 22 28 18 28;" VBox.vgrow="ALWAYS">

							<!-- File Selection Section -->
							<VBox spacing="8.0">
								<HBox spacing="8.0" style="-fx-alignment: CENTER_LEFT;">
									<Label style="-fx-font-size:14px;" text="📁" />
									<Label id="sectionLabel" text="Select User XML File" />
								</HBox>

								<HBox spacing="10.0" style="-fx-alignment: CENTER_LEFT;">
									<Label id="pathField" fx:id="labelUserLocation" maxWidth="1.7976931348623157E308" text="Path : " textFill="#374151" wrapText="false" HBox.hgrow="ALWAYS">
										<font>
											<Font name="Segoe UI" size="13.0" />
										</font>
									</Label>
									<Button fx:id="btnUserFile" minWidth="100.0" onAction="#browseUserFile" text="Browse" />
								</HBox>
							</VBox>

							<!-- Divider -->
							<Region maxHeight="1.0" minHeight="1.0" prefHeight="1.0" style="-fx-background-color: #E5E7EB;" />

							<!-- Actions Section -->
							<VBox spacing="10.0">
								<HBox spacing="8.0" style="-fx-alignment: CENTER_LEFT;">
									<Label style="-fx-font-size:14px;" text="⚙" />
									<Label id="sectionLabel" text="Data Processing" />
								</HBox>

								<HBox spacing="12.0" style="-fx-alignment: CENTER_LEFT;">
									<Button id="actionBtn" minWidth="110.0" onAction="#validateUserXMLData" text="Validate XML" />
									<Button id="actionBtn" minWidth="100.0" onAction="#readUserXMLData" text="Get Data" />
      
      							<!-- Records Count -->
      							<Label id="recordsCountLabel" fx:id="totalUserRecordsCount" text="Total Records : -" visible="false">
      								<font>
      									<Font name="Segoe UI Semibold" size="13.0" />
      								</font>
      							</Label>
								</HBox>
							</VBox>

							<!-- Table -->
							<TableView id="reportTableView" fx:id="userRecordTableView" maxHeight="1.7976931348623157E308" visible="false" VBox.vgrow="ALWAYS">
								<effect>
									<DropShadow color="#00000012" offsetY="2" radius="10" />
								</effect>
							</TableView>

						</VBox>

						<!-- Divider -->
						<Region maxHeight="1.0" minHeight="1.0" prefHeight="1.0" style="-fx-background-color: #E5E7EB;" />

						<!-- Footer -->
						<HBox spacing="12.0" style="-fx-alignment: CENTER; -fx-padding: 16 28 20 28;">
							<Button fx:id="importUserButton" disable="true" onAction="#importUserButtonAction" text="Import" />
						</HBox>

					</VBox>
				</AnchorPane>
			</content>
		</Tab>

