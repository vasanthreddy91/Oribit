						<Region maxHeight="1.0" minHeight="1.0" prefHeight="1.0" style="-fx-background-color: #E5E7EB;" />

						<HBox spacing="12.0" style="-fx-alignment: CENTER; -fx-padding: 16 28 20 28;">
