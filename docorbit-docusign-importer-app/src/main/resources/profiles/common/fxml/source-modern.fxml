<TabPane fx:id="setupTabPane" minHeight="400.0" minWidth="600.0" prefHeight="545.0" prefWidth="846.0" tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.techtiera.docorbit.controller.SourceController">
	<tabs>

		<!-- ===== USERS TAB ===== -->
		<Tab text="Users">
			<content>
				<AnchorPane style="-fx-background-color: #F0F2F5;">

					<!-- Main Card -->
					<VBox id="mainCard" spacing="0" AnchorPane.bottomAnchor="24.0" AnchorPane.leftAnchor="24.0" AnchorPane.rightAnchor="24.0" AnchorPane.topAnchor="24.0">

						<!-- Header -->
